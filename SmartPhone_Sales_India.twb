      <aliases enabled='yes' />
      <column caption='Price_Category' datatype='string' name='[Calculation_1276600380403712]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Original Price]&lt;=10000 THEN &quot;Budget&quot;&#13;&#10;ELSEIF [Original Price]&lt;30000 THEN &quot;Mid Budget&quot;&#13;&#10;ELSE &quot;Premium&quot;&#13;&#10;END' />
      </column>
      <column caption='Total_Discount' datatype='real' name='[Calculation_1276600381321217]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Original Price]-[final_price]' />
      </column>
      <column caption='Value_Category' datatype='string' name='[Calculation_1276600381779970]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [value_score]&gt; 0.0002 THEN &quot;High Value&quot;&#13;&#10;ELSEIF [value_score]&gt;0.0001 THEN &quot;Mid Value&quot;&#13;&#10;ELSE &quot;Low Value&quot;&#13;&#10;END' />
      </column>
      <column caption='Rating_Category' datatype='string' name='[Calculation_1276600382394371]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Rating]&gt;=4.5 THEN&quot;Excellent&quot;&#13;&#10;ELSEIF [Rating]&gt;=4 THEN&quot;Good&quot;&#13;&#10;ELSE &quot;Average&quot;&#13;&#10;END' />
      </column>
      <column caption='Round_Price' datatype='real' name='[Calculation_1276600382943236]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND([Original Price],0)' />
      </column>
      <column caption='KPI' datatype='string' name='[Calculation_1276600392704005]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;Avg Price: ₹&quot; + STR(ROUND(AVG([Original Price]),0)) +&#13;&#10;&quot;\nAvg Rating: &quot; + STR(ROUND(AVG([Rating]),1)) +&#13;&#10;&quot;\nTotal Phones: &quot; + STR(COUNT([Models])) +&#13;&#10;&quot;\nAvg Discount: &quot; + STR(ROUND(AVG([discount percentage]),1)) + &quot;%&quot;' />
      </column>
      <column datatype='real' default-format='n#,##0.0;-#,##0.0' name='[Rating]' role='measure' type='quantitative' />
      <column caption='cleaned_smartphone_data.csv' datatype='table' name='[__tableau_internal_object_id__].[cleaned_smartphone_data.csv_74BD9CFB16B8401E942E7E63AA8937BA]' role='measure' type='quantitative' />
